COGNITO_USER_POOL_ID=mock-pool-id
COGNITO_CLIENT_ID=mock-client-id

# Local Testing Bypass
OFFLINE_MODE=true
MOCK_TENANT_ID=00000000-0000-0000-0000-000000000001
MOCK_USER_ID=00000000-0000-0000-0000-000000000002
